{
  "agent": "codex",
  "displayName": "OpenAI Codex CLI",
  "officialDocs": {
    "config": "https://developers.openai.com/codex/config-basic",
    "reference": "https://developers.openai.com/codex/config-reference",
    "mcp": "https://developers.openai.com/codex/mcp"
  },
  "verifiedAt": "2026-05-20",
  "capabilities": {
    "supportsSkills": true,
    "supportsWorkflows": true,
    "supportsMcp": true,
    "supportsSymlink": true
  },
  "assetLayouts": {
    "skills": "codex_skill_package",
    "workflows": "standard_tree",
    "mcp": "standard_tree",
    "agents": "standard_tree"
  },
  "targetCandidates": {
    "skills": [
      "${PROJECT_ROOT}/.codex/skills/ai-coordinator",
      "~/.codex/skills/ai-coordinator"
    ],
    "workflows": [
      "${PROJECT_ROOT}/.codex/workflows/ai-coordinator",
      "~/.codex/workflows/ai-coordinator"
    ],
    "mcp": [
      "${PROJECT_ROOT}/.codex/mcp/ai-coordinator",
      "~/.codex/mcp/ai-coordinator"
    ],
    "agents": [
      "${PROJECT_ROOT}/.codex/agents/ai-coordinator",
      "~/.codex/agents/ai-coordinator"
    ]
  },
  "notes": [
    "Codex config precedence includes project and user config layers.",
    "Use project-local targets when repository-scoped behavior is required."
  ]
}
